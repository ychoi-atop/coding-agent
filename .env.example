# Copy to .env and fill values for your gateway/provider.
# Do NOT commit real secrets.

# --- OpenAI-compatible providers (OpenRouter / LM Studio proxy / Ollama proxy / etc.) ---
# OpenRouter specifically requires an OpenRouter API key (OAuth token won't work there).
# OpenClaw OAuth bridge (http://127.0.0.1:18789/v1) can use any non-empty dummy value
# because AutoDev requires Bearer header construction even when auth is handled upstream.
AUTODEV_LLM_API_KEY="openclaw-dummy"

# --- OAuth path ---
# Use ONLY when your chat/completions gateway explicitly supports OAuth Bearer tokens.
# (Do not use this for OpenRouter.)
# AUTODEV_CLAUDE_CODE_OAUTH_TOKEN="<your-oauth-token>"

# Optional runtime override (CLI --model has higher priority)
AUTODEV_LLM_MODEL="anthropic/claude-opus-4-6"
