{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autodev.local/schemas/autonomous_failure_taxonomy_v2.schema.json",
  "title": "Autonomous Failure Taxonomy v2",
  "type": "object",
  "required": [
    "policy_id",
    "version",
    "failure_classes",
    "drill_examples"
  ],
  "properties": {
    "policy_id": {
      "type": "string",
      "const": "autonomous.failure-taxonomy.v2"
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+$"
    },
    "failure_classes": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/failureClass"
      }
    },
    "drill_examples": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/drillExample"
      }
    }
  },
  "$defs": {
    "retryability": {
      "type": "string",
      "enum": [
        "retryable",
        "non_retryable"
      ]
    },
    "remediationLane": {
      "type": "string",
      "enum": [
        "auto_fix",
        "manual",
        "escalate"
      ]
    },
    "failureClass": {
      "type": "object",
      "required": [
        "id",
        "retryability",
        "remediation_lane",
        "code_families",
        "owner_team",
        "rationale"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "retryability": {
          "$ref": "#/$defs/retryability"
        },
        "remediation_lane": {
          "$ref": "#/$defs/remediationLane"
        },
        "code_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "owner_team": {
          "type": "string",
          "minLength": 2
        },
        "rationale": {
          "type": "string",
          "minLength": 10
        }
      },
      "additionalProperties": false
    },
    "drillExample": {
      "type": "object",
      "required": [
        "id",
        "failure_class",
        "typed_code",
        "expected_lane"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z]{2,4}-\\d{2,3}$"
        },
        "failure_class": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "typed_code": {
          "type": "string",
          "minLength": 5
        },
        "expected_lane": {
          "$ref": "#/$defs/remediationLane"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
