{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://coding-agent.local/schemas/autonomous_stage_boundary_contract.schema.json",
  "title": "Autonomous Stage Boundary Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_id", "version", "stages"],
  "properties": {
    "contract_id": {
      "type": "string",
      "const": "autonomous.stage-boundary.v1"
    },
    "version": {
      "type": "string",
      "pattern": "^v\\d+$"
    },
    "stages": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/stageContract"
      }
    }
  },
  "$defs": {
    "stageContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "required_inputs", "required_outputs", "failure_semantics"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["ingest", "plan", "execute", "verify"]
        },
        "required_inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "failure_semantics": {
          "$ref": "#/$defs/failureSemantics"
        }
      }
    },
    "failureSemantics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retry_class", "stop_condition", "escalate_condition", "evidence_required"],
      "properties": {
        "retry_class": {
          "type": "string",
          "enum": ["retryable", "conditional", "non_retryable"]
        },
        "stop_condition": {
          "type": "string",
          "minLength": 5
        },
        "escalate_condition": {
          "type": "string",
          "minLength": 5
        },
        "evidence_required": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
