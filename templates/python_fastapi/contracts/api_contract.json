{
  "title": "AutoDev API Contract",
  "schemas": {
    "ErrorResponse": {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": {"type": "string"},
            "message": {"type": "string"},
            "details": {"type": "object"}
          }
        }
      }
    },
    "HealthResponse": {
      "type": "object",
      "required": ["ok"],
      "properties": {
        "ok": {"type": "boolean"}
      }
    },
    "EchoRequest": {
      "type": "object",
      "required": ["payload"],
      "properties": {
        "payload": {"type": "string"},
        "repeat": {"type": "integer", "minimum": 1, "maximum": 3}
      }
    },
    "EchoResponse": {
      "type": "object",
      "required": ["payload", "repeats", "values"],
      "properties": {
        "payload": {"type": "string"},
        "repeats": {"type": "integer"},
        "values": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "endpoints": [
    {
      "method": "get",
      "path": "/health",
      "request": null,
      "responses": {
        "200": {
          "content_type": "application/json",
          "schema_ref": "HealthResponse",
          "example": {"ok": true}
        }
      }
    },
    {
      "method": "post",
      "path": "/echo",
      "request": {
        "content_type": "application/json",
        "schema_ref": "EchoRequest"
      },
      "responses": {
        "200": {
          "content_type": "application/json",
          "schema_ref": "EchoResponse"
        }
      }
    }
  ]
}
